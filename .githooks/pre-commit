#!/bin/sh

# Get all staged C/C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|cpp|cc|cxx|h|hpp)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Format each file and re-stage it
for FILE in $STAGED_FILES; do
  clang-format -i "$FILE"
  git add "$FILE"
done

exit 0
